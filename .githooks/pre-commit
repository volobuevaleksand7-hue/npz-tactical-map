#!/usr/bin/env bash
# NPZ TACTICAL MAP — pre-commit guard.
# Refuses any commit that would record git conflict / stash markers under data/.
# Enable with:  git config core.hooksPath .githooks
# (agents/git-sync.sh enables this automatically on first run.)
#
# It inspects the STAGED content (the index), not the working tree, so it catches
# exactly what is about to be committed.
set -uo pipefail

PROTECTED_UI_RE='^(index\.html|styles\.css|app\.js|radar\.html|version\.json|CHANGELOG\.md|\.vercelignore)$'
protected_ui="$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E "$PROTECTED_UI_RE" || true)"
if [ -n "$protected_ui" ] && [ "${ALLOW_FRONTEND_RELEASE:-}" != "1" ]; then
  echo "pre-commit: BLOCKED — protected UI/release files are staged:" >&2
  printf '%s\n' "$protected_ui" | sed 's/^/    /' >&2
  echo "pre-commit: set ALLOW_FRONTEND_RELEASE=1 only for an intentional UI/release commit." >&2
  exit 1
fi

# Files staged for commit under data/ (added/copied/modified/renamed).
staged="$(git diff --cached --name-only --diff-filter=ACMR -- data/ 2>/dev/null)"
[ -z "$staged" ] && exit 0

bad=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  # Read the staged blob (not the working file) and look for conflict markers.
  if git show ":$f" 2>/dev/null | grep -nE '^(<<<<<<<|=======|>>>>>>>)' >/dev/null; then
    echo "pre-commit: BLOCKED — $f contains conflict/stash markers:" >&2
    git show ":$f" 2>/dev/null | grep -nE '^(<<<<<<<|=======|>>>>>>>)' | sed 's/^/    /' >&2
    bad=1
  fi
done <<< "$staged"

if [ "$bad" = "1" ]; then
  echo "pre-commit: fix the marker(s) above and re-stage. Commit aborted." >&2
  exit 1
fi

# ---- archive-shrink guard: strikes.json — полный архив, коллекторы только дописывают ----
# Дважды (июнь: 168→110, 08.07: 147→5) облачный коллектор перезаписывал архив свежим
# снапшотом. Блокируем коммит, если число strikes падает >10%. Обход: ALLOW_STRIKES_SHRINK=1.
if echo "$staged" | grep -q '^data/strikes\.json$' && [ "${ALLOW_STRIKES_SHRINK:-}" != "1" ] && command -v python3 >/dev/null 2>&1; then
  old_n="$(git show HEAD:data/strikes.json 2>/dev/null | python3 -c 'import json,sys;print(len(json.load(sys.stdin).get("strikes",[])))' 2>/dev/null || echo 0)"
  new_n="$(git show :data/strikes.json 2>/dev/null | python3 -c 'import json,sys;print(len(json.load(sys.stdin).get("strikes",[])))' 2>/dev/null || echo 0)"
  if [ "$old_n" -gt 20 ] && [ "$new_n" -lt "$((old_n * 9 / 10))" ]; then
    echo "pre-commit: BLOCKED — data/strikes.json усыхает: $old_n → $new_n записей." >&2
    echo "pre-commit: strikes.json — ПОЛНЫЙ архив, коллекторы только дописывают." >&2
    echo "pre-commit: осознанная чистка → ALLOW_STRIKES_SHRINK=1." >&2
    exit 1
  fi
fi

# ---- archive-shrink guard: fuel-voices.json — накопительный архив голосов ----
# 15.07: 96 → 67 → 0. Обнулил НЕ сам fuel-voices: git-sync делает `git add data/` и сгребает
# пустой/недописанный файл с диска (обнуление прилетело в коммите data(radar)), а следующий
# прогон агента читает уже пустое и увековечивает. Здесь НЕ блокируем (в отличие от strikes):
# коммит с голосами делают и другие рутины, а radar тикает каждые 5 мин — блок заклинил бы
# публикацию. Вместо этого восстанавливаем архив из HEAD и перезакладываем — данные целы,
# конвейер жив. Осознанная чистка → ALLOW_VOICES_SHRINK=1.
if echo "$staged" | grep -q '^data/fuel-voices\.json$' && [ "${ALLOW_VOICES_SHRINK:-}" != "1" ] && command -v python3 >/dev/null 2>&1; then
  v_old="$(git show HEAD:data/fuel-voices.json 2>/dev/null | python3 -c 'import json,sys;print(len(json.load(sys.stdin).get("voices",[])))' 2>/dev/null || echo 0)"
  v_new="$(git show :data/fuel-voices.json 2>/dev/null | python3 -c 'import json,sys;print(len(json.load(sys.stdin).get("voices",[])))' 2>/dev/null || echo 0)"
  if [ "$v_old" -gt 20 ] && [ "$v_new" -lt "$((v_old * 9 / 10))" ]; then
    if git show HEAD:data/fuel-voices.json > data/fuel-voices.json 2>/dev/null; then
      git add data/fuel-voices.json
      echo "pre-commit: fuel-voices.json усыхал ($v_old → $v_new голосов) — АРХИВ ВОССТАНОВЛЕН из HEAD и перезаложен." >&2
      echo "pre-commit: осознанная чистка → ALLOW_VOICES_SHRINK=1." >&2
    fi
  fi
fi

# ---- neutral-OSINT guard: вычистить пропаганду / укр-вербатим / офф-топик из strikes ----
# Ловит ЛЮБОЙ коммит (newswatch, ручной, внешняя модель), т.к. core.hooksPath=.githooks.
# Санитайзер идемпотентен и авто-перезакладывает очищенный файл — коммит не блокируется,
# но мусор физически не попадает в data/strikes.json (и на сайт/в Telegram).
if [ -f agents/sanitize-strikes.py ] && command -v python3 >/dev/null 2>&1; then
  for _f in data/strikes.json data/history-crimea.json; do
    if echo "$staged" | grep -q "^$_f$"; then
      python3 agents/sanitize-strikes.py "$_f" >&2 || true
      if ! git diff --quiet -- "$_f" 2>/dev/null; then
        git add "$_f"
        echo "pre-commit: sanitize-strikes очистил $_f и перезаложил его в коммит." >&2
      fi
    fi
  done
fi

# ---- future-dates guard: событие не может произойти позже момента записи ----
# 15.07 агент записал удар по Балаклавской ТЭС как «15.07 23:10», когда было 13:44 МСК
# (реально — ночь на 14.07). Модель текущего времени не знает и берёт дату из головы.
# Метаполя (generated_at) скрипт чинит сам и молча; запись из будущего — БЛОКИРУЕТ:
# правильного времени мы не знаем, а угадать = подделать. Удалять запись тоже нельзя
# (усыхание архива). Осознанный бэкфилл → ALLOW_FUTURE_DATES=1.
# Идёт ПОСЛЕ санитайзера: тот перезакладывает файл, проверять надо итог.
if [ -f agents/check-future-dates.py ] && command -v python3 >/dev/null 2>&1; then
  for _f in data/strikes.json data/history-crimea.json; do
    if echo "$staged" | grep -q "^$_f$"; then
      if ! python3 agents/check-future-dates.py "$_f" >&2; then
        echo "pre-commit: BLOCKED — даты из будущего в $_f (см. выше). Commit aborted." >&2
        exit 1
      fi
      if ! git diff --quiet -- "$_f" 2>/dev/null; then
        git add "$_f"
        echo "pre-commit: check-future-dates поправил метку времени в $_f." >&2
      fi
    fi
  done
fi
exit 0
